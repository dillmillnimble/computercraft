-- Drill Tracker Turtle
-- Sits on the contraption and broadcasts GPS position wirelessly

local CHANNEL = 42        -- must match base station
local UPDATE_RATE = 2     -- seconds between updates

-- Attach wireless modem
local modem = peripheral.find("modem")
if not modem then
  print("ERROR: No modem found!")
  return
end
modem.open(CHANNEL)

print("Drill Tracker Online!")
print("Broadcasting on channel " .. CHANNEL)

-- Box boundaries (your corners)
local MIN_X = 275
local MAX_X = 446
local MIN_Z = -488
local MAX_Z = -382

local startTime = os.time()

while true do
  local x, y, z = gps.locate(5)

  if x ~= nil then
    local data = {
      x = math.floor(x),
      y = math.floor(y),
      z = math.floor(z),
      fuel = turtle.getFuelLevel(),
      time = os.time()
    }
    modem.transmit(CHANNEL, CHANNEL, data)
    print("Sent: X" .. data.x .. " Z" .. data.z .. " Fuel:" .. data.fuel)
  else
    print("GPS signal lost!")
    modem.transmit(CHANNEL, CHANNEL, {error = "GPS lost"})
  end

  sleep(UPDATE_RATE)
end