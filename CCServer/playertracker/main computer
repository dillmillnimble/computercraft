-- tracker_display.lua
-- Run on an Advanced Computer connected to an Advanced Monitor

local monitor = peripheral.find("monitor")
local modem = peripheral.find("modem")

if not monitor or not modem then
  print("Need a monitor AND a wireless modem attached!")
  return
end

modem.open(99)
monitor.setTextScale(0.5)

local players = {} -- { name = { x, y, z, lastSeen } }

-- Map display settings
local mapCenterX = 0    -- change to your base coords
local mapCenterZ = 0
local mapScale = 2      -- blocks per character cell

local function worldToScreen(wx, wz, sw, sh)
  local sx = math.floor((wx - mapCenterX) / mapScale + sw / 2)
  local sy = math.floor((wz - mapCenterZ) / mapScale + sh / 2)
  return sx, sy
end

local colors = {
  colors.yellow, colors.cyan, colors.lime, colors.pink,
  colors.orange, colors.lightBlue, colors.magenta, colors.red
}
local playerColors = {}
local colorIndex = 1

local function getPlayerColor(name)
  if not playerColors[name] then
    playerColors[name] = colors[colorIndex]
    colorIndex = (colorIndex % #colors) + 1
  end
  return playerColors[name]
end

local function drawMap()
  monitor.clear()
  local sw, sh = monitor.getSize()

  -- Draw border
  monitor.setBackgroundColor(colors.black)
  monitor.setTextColor(colors.gray)
  monitor.setCursorPos(1, 1)
  monitor.write("[ PLAYER TRACKER ]")

  -- Draw grid center marker
  local cx, cy = worldToScreen(mapCenterX, mapCenterZ, sw, sh)
  if cx >= 1 and cx <= sw and cy >= 2 and cy <= sh then
    monitor.setBackgroundColor(colors.black)
    monitor.setTextColor(colors.gray)
    monitor.setCursorPos(cx, cy)
    monitor.write("+")
  end

  -- Draw each player
  local now = os.clock()
  for name, data in pairs(players) do
    -- Remove stale players (not seen in 10 seconds)
    if now - data.lastSeen > 10 then
      players[name] = nil
    else
      local sx, sy = worldToScreen(data.x, data.z, sw, sh)

      if sx >= 1 and sx <= sw and sy >= 2 and sy <= sh then
        local col = getPlayerColor(name)

        -- Draw name above icon (if space)
        if sy - 1 >= 2 then
          monitor.setCursorPos(sx - math.floor(#name / 2), sy - 1)
          monitor.setBackgroundColor(colors.black)
          monitor.setTextColor(col)
          monitor.write(name)
        end

        -- Draw player icon ( ☺ or * )
        monitor.setCursorPos(sx, sy)
        monitor.setBackgroundColor(col)
        monitor.setTextColor(colors.black)
        monitor.write("@")
      end
    end
  end

  -- Draw legend at bottom
  monitor.setBackgroundColor(colors.black)
  monitor.setTextColor(colors.white)
  monitor.setCursorPos(1, sh)
  monitor.write("Scale:" .. mapScale .. "b/cell  Center:" .. mapCenterX .. "," .. mapCenterZ)
end

-- Main loop: listen for broadcasts and redraw
print("Tracker running! Listening on channel 99...")

while true do
  -- Non-blocking: redraw every 0.5s, receive when available
  local event, side, channel, replyChannel, message = os.pullEvent("modem_message")

  if channel == 99 then
    local ok, data = pcall(textutils.unserialise, message)
    if ok and data and data.name and data.x then
      players[data.name] = {
        x = data.x,
        y = data.y,
        z = data.z,
        lastSeen = os.clock()
      }
    end
  end

  drawMap()
end